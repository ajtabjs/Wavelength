---
layout: base.njk
title: Play
permalink: /play/index.html
---

<div class="play-page" id="play-page">

  <div class="play-header" id="play-header">
    <a href="javascript:history.back()" class="play-back">← Back</a>
    <h1 class="play-title" id="play-title">Loading…</h1>
    <span class="play-type-badge" id="play-type-badge"></span>
  </div>

  <div class="play-frame-wrap" id="play-frame-wrap">
    <iframe
      id="game-frame"
      class="game-frame"
      src=""
      title="Game"
      allowfullscreen
      sandbox="allow-scripts allow-same-origin allow-forms allow-pointer-lock allow-top-navigation"
    ></iframe>
    <div class="play-error" id="play-error" hidden>
      <p>Could not load game. <a href="/">Return to games list.</a></p>
    </div>
  </div>

</div>

<script>
  (function () {
    const BASE_URLS = {
      html: "{{ baseUrls.html }}",
      ruffle: "{{ baseUrls.ruffle }}",
      webPorts: "{{ baseUrls.webPorts }}"
    };

    const TYPE_LABELS = {
      html: "HTML5",
      ruffle: "Flash / Ruffle",
      webPorts: "Web Port"
    };

    const params = new URLSearchParams(window.location.search);
    const slug = params.get("game");
    const type = params.get("type");

    const titleEl = document.getElementById("play-title");
    const badgeEl = document.getElementById("play-type-badge");
    const frame   = document.getElementById("game-frame");
    const errorEl = document.getElementById("play-error");

    if (!slug || !type || !BASE_URLS[type]) {
      titleEl.textContent = "Game not found";
      frame.hidden = true;
      errorEl.hidden = false;
      return;
    }

    // Fetch the matching game entry from the pre-baked JSON for this type.
    // We fetch the JSON at runtime so the play page stays a single static file.
    const jsonMap = {
      html:      "/data/htmlGames.json",
      ruffle:    "/data/ruffleGames.json",
      webPorts:  "/data/webPorts.json"
    };

    fetch(jsonMap[type])
      .then(r => {
        if (!r.ok) throw new Error("JSON fetch failed");
        return r.json();
      })
      .then(games => {
        const game = games.find(g => g.slug === slug);
        if (!game) throw new Error("Game not found in list");

        document.title = `${game.name} — Games`;
        titleEl.textContent = game.name;
        badgeEl.textContent = TYPE_LABELS[type] || type;
        badgeEl.className = `play-type-badge play-type-badge--${type}`;

        const gameUrl = `${BASE_URLS[type]}/${game.path}`;
        frame.src = gameUrl;
      })
      .catch(err => {
        console.error(err);
        titleEl.textContent = "Error loading game";
        frame.hidden = true;
        errorEl.hidden = false;
      });
  })();
</script>
